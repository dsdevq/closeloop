# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/

# Vite build output — frontend/vite.config.ts writes to ../app/static; the
# Dockerfile builds it in-image (stage 1). NEVER commit bundles: they rot
# against frontend/ source and pollute every diff. .gitkeep keeps the dir
# present so app/main.py's StaticFiles mount doesn't crash on fresh clones.
app/static/*
!app/static/.gitkeep
build/
.venv/
venv/
env/

# SQLite databases — ephemeral artefacts, never commit
*.db
*.db-journal
*.db-shm
*.db-wal

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/

# Node / frontend
node_modules/
frontend/node_modules/
frontend/.vite/
*.tsbuildinfo

# OS
.DS_Store

# Playwright test artifacts (screenshots/traces from failed runs)
test-results/.playwright-artifacts-*/
playwright-report/
/.devclaw/
